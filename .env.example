# ─── Karaokê IA — Variáveis de Ambiente ───────────────────────────────
# Copie este arquivo para .env e ajuste conforme necessário.

# Idioma padrão para transcrição Whisper
WHISPER_LANGUAGE=pt

# Host/porta da API
API_HOST=127.0.0.1
API_PORT=8000

# Forçar dispositivo (cpu, cuda) — vazio = auto-detect
WHISPER_DEVICE=
WHISPER_COMPUTE_TYPE=
